---
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import Div_blog from '../../components/Div_blog.astro';
import Search_bar from '../../components/Search_bar.astro';
import BaseHead from '../../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const post_blog = [
  {
    title: 'first-post',
    url: '/blog/first-post/',
    excerpt:
      'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Vitae ultricies leo integer malesuada nunc vel risus commodo viverra. Adipiscing enim eu turpis egestas pretium.',
  },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <div class="searcher">
      <Search_bar />
    </div>
    <div class="blog_browser" id="blogContainer">
      {
        post_blog.map((blog) => (
          <Div_blog title={blog.title} url={blog.url} excerpt={blog.excerpt} />
        ))
      }
    </div>
    <footer>
      <p>Copyright © 2026 DDLG. All rights reserved.</p>
    </footer>
  </body><script>
    // 1. 获取搜索框和所有的博客卡片
    const searchInput = document.getElementById('searchInput');
    const blogCards = document.querySelectorAll('.blog-card-item');

    if (searchInput) {
      // 2. 监听用户在搜索框里的输入事件

      searchInput.addEventListener('input', (event) => {
        // 获取用户输入的词，并转成小写
        const searchTerm = event.target.value.toLowerCase();

        // 3. 遍历每一个卡片，判断要不要显示
        blogCards.forEach((card) => {
          // 从我们在组件里设置的 data-title 属性获取标题
          const title = card.getAttribute('data-title');

          // 如果标题包含搜索词，就显示；否则，就隐藏
          if (title.includes(searchTerm)) {
            card.style.display = 'block'; // 或者保持你原本的网格 display
          } else {
            card.style.display = 'none'; // 隐藏不匹配的卡片
          }
        });
      });
    } else {
      blogCards.forEach((card) => {
        card.style.display = 'block';
      });
    }
  </script>
  <style>
    .searcher {
      display: flex;
      justify-content: center;
      align-items: center;
      margin: 20px;
    }
    .blog_browser {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
      margin: 20px;
    }
  </style>
</html>
